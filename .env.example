# Local runtime defaults. Copy to .env and edit for your machine.
# Keep .env private; it is ignored by git.

YERELLM_HOST=127.0.0.1
YERELLM_PORT=8000
YERELLM_CKPT=checkpoints/ckpt.pt
YERELLM_ADAPTER=auto
YERELLM_TOKENIZER=tokenizer/tokenizer.json
YERELLM_REGISTRY_DB=state/local_nodes.db
YERELLM_DEFAULT_CITY=Istanbul

# Set a long random value before using --host 0.0.0.0 or worker nodes.
# Example: openssl rand -hex 32
YERELLM_API_TOKEN=change-me
YERELLM_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Chat behavior.
YERELLM_CHAT_BACKEND=local
YERELLM_CHAT_QUICK_MODE=model_first
YERELLM_CHAT_FALLBACK_MODE=quality_message
YERELLM_CHAT_WORKER_TIMEOUT_SEC=180

# Worker setup defaults.
YERELLM_WORKER_CONFIG=.yerellm_worker.env
YERELLM_SERVER_URL=http://127.0.0.1:8000
YERELLM_WORKER_NAME=local-worker
YERELLM_NODE_ID=
YERELLM_NODE_ROLE=worker
YERELLM_REPO=.
YERELLM_DEVICE=auto
YERELLM_BASE_URL=
YERELLM_HEARTBEAT_SEC=10
YERELLM_COMMAND_TIMEOUT_SEC=3600
YERELLM_TRAINING_TIMEOUT_SEC=7200
YERELLM_ALLOW_TRAINING_JOBS=true
YERELLM_ALLOW_REMOTE_COMMANDS=false

# Optional remote chat dataset sync.
YERELLM_CHAT_SYNC_URL=
YERELLM_CHAT_SYNC_SHA256=
YERELLM_ENABLE_CHAT_SYNC_AUTO=false
YERELLM_DISABLE_CHAT_SYNC=false

# Local DDP helpers.
MASTER_ADDR=127.0.0.1
MASTER_PORT=29500
USE_LIBUV=0
NNODES=1
NODE_RANK=0
LOCAL_RANK=0
PRESET=small-100m
DATA=data/bin
PYTHON_BIN=python
