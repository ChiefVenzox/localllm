# Copy this file to .env for Docker Compose local defaults.
# Keep real tokens/passwords in .env only. .env is ignored by git.

COMPOSE_PROJECT_NAME=localllm
PYTHON_VERSION=3.12
YERELLM_PORT=8000
YERELLM_HOST=0.0.0.0

# Runtime files are mounted from ./checkpoints, ./data and ./state.
YERELLM_CKPT=/app/checkpoints/ckpt.pt
YERELLM_ADAPTER=auto
YERELLM_TOKENIZER=/app/tokenizer/tokenizer.json
YERELLM_REGISTRY_DB=/app/state/local_nodes.db
YERELLM_DEFAULT_CITY=Istanbul

# Set a long random value before exposing the API outside localhost.
# Example: openssl rand -hex 32
YERELLM_API_TOKEN=change-me

# CUDA PyTorch wheel used during image build.
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu126
INSTALL_BITSANDBYTES=0

# Worker defaults.
YERELLM_SERVER_URL=http://api:8000
YERELLM_WORKER_NAME=docker-worker
YERELLM_NODE_ID=docker-worker
YERELLM_NODE_ROLE=docker
YERELLM_WORKER_DEVICE=auto
YERELLM_ALLOW_TRAINING_JOBS=true
YERELLM_ALLOW_REMOTE_COMMANDS=false
